# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# URL llama-server (OpenAI-compatible API)
LLAMA_SERVER_URL=http://127.0.0.1:8080/v1/chat/completions

# Telegram ID владельца бота (для доступа к админ-командам)
# Узнать через @userinfobot
OWNER_ID=123456789

# Режим обработки обычных сообщений как запросов к модели
# true - обрабатывать все сообщения как запросы
# false - только команда /ask
DEFAULT_MODE=true

# Размер чанка для стриминга (символов)
STREAM_CHUNK_SIZE=50

# Таймаут запроса к llama-server (секунды)
# Для медленных локальных моделей с thinking рекомендуется 600-1200 секунд
REQUEST_TIMEOUT=600

# Интервал проверки доступности llama-server (секунды)
# Увеличен для предотвращения прерывания медленной генерации
SERVER_CHECK_INTERVAL=120

# Максимальное количество токенов в ответе
MAX_TOKENS=8192

# Режим thinking-модели (размышления)
# true - показывать размышления модели
# false - скрывать размышления
SHOW_THINKING=true

# Rate limiting: максимум запросов в минуту от одного пользователя
RATE_LIMIT_MAX_REQUESTS=10

# Rate limiting: окно времени в минутах
RATE_LIMIT_WINDOW=1
